# Neon PostgreSQL — use pooled URL for the app; for migrations some setups use a direct (non-pooler) URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# Optional: protect cron route (generate random string)
CRON_SECRET=""

# Public URL of the app (optional, for metadata)
NEXTAUTH_URL="http://localhost:3000"

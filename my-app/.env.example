# Neon PostgreSQL — pooled URL for the app runtime (?sslmode=require).
# Query string must use real ampersands: ...?sslmode=require&channel_binding=require  (never &amp;)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Direct (non-pooler) host for Prisma migrations — same DB/user/password, hostname without "-pooler".
# In Neon dashboard: copy the "direct" connection string or strip "-pooler" from the pooler host.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Neon troubleshooting (Prisma "Can't reach database server"):
# - Neon dashboard → project/branches → resume if paused; confirm connection strings were copied correctly.
# - Local: DATABASE_URL/DIRECT_URL in `.env`; restart `npm run dev`.
# - Vercel: Project → Settings → Environment Variables → same DATABASE_URL + DIRECT_URL for Production and Preview → Redeploy.
# - Rare: Neon IP allowlist — allow Vercel egress if you tightened network rules.

# Clerk — https://dashboard.clerk.com → API Keys
# For production: use a production Clerk instance (pk_live_ / sk_live_) and add your Vercel domain in Clerk.
# Vercel: set these in Project → Environment Variables, then Redeploy. NEXT_PUBLIC_* is embedded at build time.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Optional: protect cron route (random string); Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Canonical URL (production: https://your-domain.vercel.app — no trailing slash)
# Clerk may use this for redirects in some setups.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional Clerk redirect defaults (see Clerk env docs). `<SignIn/>` / `<SignUp/>` in this app
# also set `fallbackRedirectUrl="/chat"` so post-auth lands on `/chat` without these.
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/chat"
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/chat"

# --- Vercel (mirror .env locally; never commit real values) ---
# 1. Git repo: if the app lives in this folder, set Vercel "Root Directory" to: my-app
# 2. Environment variables (Production + Preview): copy every key you use locally, especially:
#    DATABASE_URL (Neon pooler), DIRECT_URL (Neon direct, non-pooler), CLERK_SECRET_KEY,
#    NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY, NEXT_PUBLIC_APP_URL=https://<your-project>.vercel.app
# 3. After changing NEXT_PUBLIC_* or Clerk keys: trigger a new deployment (redeploy).
# 4. Database: run migrations against production once (from CI or your machine with prod env):
#    cd my-app && DATABASE_URL=... DIRECT_URL=... npx prisma migrate deploy
# 5. Clerk Dashboard → your app → Domains: add your Vercel URL (*.vercel.app and custom domain).
#    Paths: Sign-in /login, Sign-up /register (this repo uses custom routes).
# 6. CRON_SECRET: required for `/api/cron/generate-daily-summaries` (Vercel Cron sends Authorization: Bearer <CRON_SECRET>).

# --- Gemini summaries (server only; never NEXT_PUBLIC) ---
# Inference uses @google/genai only (Google AI Studio API key OR Vertex AI). Not AWS Bedrock.
#
# Daily summaries + optional cron: generateGeminiDailyArticle (vertex-daily-summary.ts).
# Clinical period summary (“last N days”): generateGeminiPeriodArticle (vertex-period-summary.ts).
#
# Routing when AI_PROVIDER=auto (default):
#   - If GEMINI_API_KEY is set → Google AI Studio wins over Vertex.
#   - Else if VERTEX_PROJECT_ID/GOOGLE_CLOUD_PROJECT + WIF credentials → Vertex AI.
#
# Force one backend for everyone:
#   AI_PROVIDER=studio   → requires GEMINI_API_KEY
#   AI_PROVIDER=vertex   → requires project + GOOGLE_EXTERNAL_ACCOUNT_JSON OR Secrets Manager below
#
# Period-only override (clinical multi-day digest): if set, ignores AI_PROVIDER for that flow only.
# Recommended if clinical summary hits Studio free-tier RPM limits (~5/min): AI_PROVIDER_PERIOD=vertex + Vertex env below.
AI_PROVIDER="auto"
AI_PROVIDER_PERIOD=""

# Google AI Studio / Gemini Developer API (personal API key from https://aistudio.google.com/apikey )
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
# Optional: Studio model for clinical period summary only (defaults to GEMINI_MODEL). Does not bypass free-tier quotas.
# GEMINI_PERIOD_MODEL=""

# --- Vertex AI (GCP; same Gemini models via vertexai: true) ---
VERTEX_PROJECT_ID=""
# Or: GOOGLE_CLOUD_PROJECT=""  (fallback if VERTEX_PROJECT_ID unset)
VERTEX_LOCATION="us-central1"
VERTEX_GEMINI_MODEL="gemini-2.0-flash-001"
VERTEX_API_VERSION="v1"

# WIF credentials for Vertex (pick ONE path):
# (A) Inline JSON string (e.g. Vercel env); OR
# (B) VERTEX_CREDENTIAL_SECRET_ID: AWS Secrets Manager secret whose JSON includes credential_json
#     (workload identity — AWS is only for fetching this secret, not for calling Gemini).
GOOGLE_EXTERNAL_ACCOUNT_JSON=""

VERTEX_CREDENTIAL_SECRET_ID=""
# Region for Secrets Manager client (not GCP region — use VERTEX_LOCATION for Gemini region).
AWS_REGION="us-east-1"
# Optional: INI file with [default] profile (same shape as ~/.aws/credentials). Overrides scattered AWS_* below when unset.
# AWS_SHARED_CREDENTIALS_FILE="/home/you/Downloads/aws_credentials (21).txt"
# Optional: only needed locally when not using IAM role or AWS_SHARED_CREDENTIALS_FILE.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""

# Dev: skip real API calls and use canned copy (cron + manual summary still write DB + chat).
VERTEX_DISABLED="false"
# When true: daily summary uses mock text, but History calorie totals still run via GEMINI_API_KEY (Studio).
# Vertex-backed calorie calls are skipped while VERTEX_DISABLED=true; use Studio key or unset this flag.

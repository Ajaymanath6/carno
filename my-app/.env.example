# Neon PostgreSQL — pooled URL recommended on Vercel (?sslmode=require).
# If connections fail from Vercel, try removing `channel_binding=require` from the URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Optional: protect cron route (random string); Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Canonical URL (production: https://your-domain.vercel.app — no trailing slash)
# Clerk may use this for redirects in some setups.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

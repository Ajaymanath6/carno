# Neon PostgreSQL — pooled URL recommended on Vercel. Use ?sslmode=require
# If Prisma fails to connect from Vercel, try removing `channel_binding=require` from the URL (some runtimes disagree with it).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# Optional: protect cron route (generate random string)
CRON_SECRET=""

# Canonical site URL (required in production on Vercel — no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

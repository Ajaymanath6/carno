# ─── Database ─────────────────────────────────────────────────────────────────
# Standard Prisma connection string for PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/mapmygig?schema=public"

# Direct non-pooled URL (required for Prisma migrations when using a pooler like pgBouncer)
DIRECT_URL="postgresql://user:password@localhost:5432/mapmygig?schema=public"

# ─── Clerk Authentication ──────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Custom sign-in / sign-up paths (must match Clerk Dashboard settings)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Optional: if you use a custom domain Clerk proxy (see proxy.ts)
# NEXT_PUBLIC_CLERK_PROXY_URL="https://yourdomain.com/__clerk"
# NEXT_PUBLIC_CLERK_JS_URL="https://unpkg.com/@clerk/clerk-js@5/dist/clerk.browser.js"

# ─── Redis Cache ──────────────────────────────────────────────────────────────
# Leave empty to use the in-memory fallback cache (great for local dev)
REDIS_URL="redis://localhost:6379"

# ─── Razorpay Payments ────────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Email (nodemailer) ───────────────────────────────────────────────────────
# SMTP credentials — works with Gmail (App Password), Mailtrap, Resend SMTP, etc.
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="587"
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
EMAIL_FROM="noreply@mapmygig.com"

# ─── App ──────────────────────────────────────────────────────────────────────
# Full public URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
